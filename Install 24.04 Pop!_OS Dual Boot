# Run rclone on startup
cat << EOF > ~/bin/Rclone
#!/bin/bash
rclone mount grive: ~/gdrive &
EOF

chmod +x ~/bin/Rclone

        
cat << EOF > ~/.config/autostart/rclone.desktop
[Desktop Entry]
Name=rclone
Exec=/home/daveg/bin/Rclone
Terminal=false
Type=Application
X-Desktop-File-Install-Version=0.27
EOF

chmod +x /home/daveg/.config/autostart/rclone.desktop
  
